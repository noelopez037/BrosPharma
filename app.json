{
  "expo": {
    "name": "Bros360",
    "slug": "BrosPharma",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "brospharma",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/app-icon.png",
      "bundleIdentifier": "com.bros360.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Permite guardar imágenes de productos en tu galería.",
        "NSPhotoLibraryAddUsageDescription": "Permite guardar imágenes en tu galería.",
        "NSCameraUsageDescription": "Permite tomar fotos de productos.",
        "NSUserNotificationsUsageDescription": "Recibe notificaciones de ventas, pedidos y alertas importantes de tu farmacia."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/app-icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.bros360.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon.png",
          "color": "#153c9e"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir acceso a tus fotos para guardar imágenes de productos.",
          "savePhotosPermission": "Permitir guardar imágenes en tu galería."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-updates"
    ],
    "runtimeVersion": "1.2.1",
    "updates": {
      "url": "https://u.expo.dev/80650541-9f6c-4199-b66f-ae8286935589"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "80650541-9f6c-4199-b66f-ae8286935589"
      },
      "privacyPolicyUrl": "https://noelopez037.github.io/bros360-legal/privacy-policy"
    },
    "owner": "noe2026"
  }
}
